<Window x:Class="EKIPPP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EKIPPP.ViewModels"
        xmlns:conv="clr-namespace:EKIPPP.Converters"
        xmlns:helpers="clr-namespace:EKIPPP.Helpers"
        Title="EKIPPP"
        Width="1100" Height="700"
        MinWidth="900" MinHeight="580"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        RenderOptions.ClearTypeHint="Enabled"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextFormattingMode="Display">

    <Window.DataContext><vm:MainViewModel/></Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="F5"  Command="{Binding RefreshStatsCommand}"/>
        <KeyBinding Key="L"   Modifiers="Control" Command="{Binding LaunchFiveMCommand}"/>
        <KeyBinding Key="D1"  Modifiers="Control" Command="{Binding SelectTabCommand}" CommandParameter="0"/>
        <KeyBinding Key="D2"  Modifiers="Control" Command="{Binding SelectTabCommand}" CommandParameter="1"/>
        <KeyBinding Key="D3"  Modifiers="Control" Command="{Binding SelectTabCommand}" CommandParameter="2"/>
        <KeyBinding Key="D4"  Modifiers="Control" Command="{Binding SelectTabCommand}" CommandParameter="3"/>
        <KeyBinding Key="D5"  Modifiers="Control" Command="{Binding SelectTabCommand}" CommandParameter="4"/>
    </Window.InputBindings>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:InverseBoolConverter      x:Key="InvBool"/>
        <conv:LogTypeToColorConverter   x:Key="LogColor"/>
        <conv:TabVisibilityConverter    x:Key="TabVis"/>
    </Window.Resources>

    <!-- Root border -->
    <Border x:Name="RootBorder" CornerRadius="16" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#07070F" Offset="0"/>
                <GradientStop Color="#0A0A16" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- Ambient glows -->
            <Ellipse Grid.Row="0" Grid.RowSpan="3" Width="600" Height="400" Opacity="0.04"
                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-80,0,0"
                     IsHitTestVisible="False">
                <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#7C3AED" Offset="0"/><GradientStop Color="Transparent" Offset="1"/></RadialGradientBrush></Ellipse.Fill>
            </Ellipse>
            <Ellipse Grid.Row="0" Grid.RowSpan="3" Width="400" Height="400" Opacity="0.035"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-80,-60"
                     IsHitTestVisible="False">
                <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#5B21B6" Offset="0"/><GradientStop Color="Transparent" Offset="1"/></RadialGradientBrush></Ellipse.Fill>
            </Ellipse>

            <!-- ══ TITLE BAR ════════════════════════════════════════════ -->
            <Grid Grid.Row="0" PreviewMouseLeftButtonDown="TitleBar_MouseDown"
                  MouseLeftButtonDown="TitleBar_DoubleClick" Background="Transparent">
                <Border BorderBrush="#14142A" BorderThickness="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#0B0B19" Offset="0"/>
                            <GradientStop Color="#09091A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                            <!-- Icône fallback (disparaît si logo.png existe) -->
                            <Border x:Name="TitleLogoFallback" Width="44" Height="44" CornerRadius="13">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C3AED" Offset="0"/>
                                        <GradientStop Color="#3B0DA8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#7C3AED" Opacity="0.85"/>
                                </Border.Effect>
                                <TextBlock Text="E" FontSize="23" FontWeight="Black" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontFamily="Segoe UI"/>
                            </Border>
                            <!-- Logo image (affiché si logo.png existe) -->
                            <Image x:Name="TitleLogoImage" Height="44" Width="44"
                                   VerticalAlignment="Center" Visibility="Collapsed"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="Uniform"/>
                            <!-- Nom de l'app — toujours visible -->
                            <StackPanel VerticalAlignment="Center" helpers:PanelSpacing.Spacing="2"
                                        Margin="14,0,0,0">
                                <TextBlock Text="EKIPPP" FontSize="21" FontWeight="Black"
                                           FontFamily="Segoe UI" Foreground="White"/>
                                <TextBlock Text="OPTIMISEUR FIVEM" FontSize="9" FontWeight="Bold"
                                           Foreground="#7C3AED" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Boutons chrome — icônes MDL2, pleine hauteur -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Stretch">
                            <!-- Minimize -->
                            <Button Click="MinimizeClick" Width="46" Height="58" Cursor="Hand"
                                    BorderThickness="0" Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent">
                                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="#9090B8"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Maximize -->
                            <Button x:Name="MaximizeButton" Click="MaximizeClick" Width="46" Height="58" Cursor="Hand"
                                    BorderThickness="0" Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent">
                                            <TextBlock x:Name="MaxIco" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="#9090B8"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Close -->
                            <Button Click="CloseClick" Width="46" Height="58" Cursor="Hand"
                                    BorderThickness="0" Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent">
                                            <TextBlock x:Name="Ico" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="#9090B8"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                                <Setter TargetName="Ico" Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#9A1B0F"/>
                                                <Setter TargetName="Ico" Property="Foreground" Value="#DDDDDD"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══ SIDEBAR + CONTENT ════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Sidebar ────────────────────────────────────────── -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="NAVIGATION"
                                   FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="20,18,20,10"/>

                        <!-- ── Nav items ── -->
                        <StackPanel DockPanel.Dock="Top">

                            <!-- Tab 0: Tableau de bord -->
                            <Border Cursor="Hand" Height="46">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding SelectTabCommand}" CommandParameter="0"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTab0Active}" Value="True">
                                                <Setter Property="Background" Value="#0F0F20"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#0C0C1C"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Rectangle Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                                               RenderTransformOrigin="0.5,0.5">
                                        <Rectangle.RenderTransform><ScaleTransform/></Rectangle.RenderTransform>
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTab0Active}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                     From="0.1" To="1" Duration="0:0:0.28">
                                                                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6"/></DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#A855F7" Offset="0"/>
                                                <GradientStop Color="#7C3AED" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <StackPanel Orientation="Horizontal" Margin="18,0,16,0" VerticalAlignment="Center"
                                                helpers:PanelSpacing.Spacing="12">
                                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="15">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Opacity" Value="0.75"/>
                                                    <Style.Triggers><DataTrigger Binding="{Binding IsTab0Active}" Value="True"><Setter Property="Opacity" Value="1"/></DataTrigger></Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Tableau de bord" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#9090C0"/>
                                                    <Style.Triggers><DataTrigger Binding="{Binding IsTab0Active}" Value="True"><Setter Property="Foreground" Value="#FFFFFF"/></DataTrigger></Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Tab 1: Nettoyage -->
                            <Border Cursor="Hand" Height="46">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding SelectTabCommand}" CommandParameter="1"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTab1Active}" Value="True"><Setter Property="Background" Value="#0F0F20"/></DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0C0C1C"/></Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Rectangle Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                                               RenderTransformOrigin="0.5,0.5">
                                        <Rectangle.RenderTransform><ScaleTransform/></Rectangle.RenderTransform>
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTab1Active}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                     From="0.1" To="1" Duration="0:0:0.28">
                                                                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6"/></DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                        <Rectangle.Fill><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#A855F7" Offset="0"/><GradientStop Color="#7C3AED" Offset="1"/></LinearGradientBrush></Rectangle.Fill>
                                    </Rectangle>
                                    <StackPanel Orientation="Horizontal" Margin="18,0,16,0" VerticalAlignment="Center" helpers:PanelSpacing.Spacing="12">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="15">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Opacity" Value="0.75"/><Style.Triggers><DataTrigger Binding="{Binding IsTab1Active}" Value="True"><Setter Property="Opacity" Value="1"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Nettoyage" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9090C0"/><Style.Triggers><DataTrigger Binding="{Binding IsTab1Active}" Value="True"><Setter Property="Foreground" Value="#FFFFFF"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Tab 2: Installation -->
                            <Border Cursor="Hand" Height="46">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding SelectTabCommand}" CommandParameter="2"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTab2Active}" Value="True"><Setter Property="Background" Value="#0F0F20"/></DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0C0C1C"/></Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Rectangle Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                                               RenderTransformOrigin="0.5,0.5">
                                        <Rectangle.RenderTransform><ScaleTransform/></Rectangle.RenderTransform>
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTab2Active}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                     From="0.1" To="1" Duration="0:0:0.28">
                                                                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6"/></DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                        <Rectangle.Fill><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#A855F7" Offset="0"/><GradientStop Color="#7C3AED" Offset="1"/></LinearGradientBrush></Rectangle.Fill>
                                    </Rectangle>
                                    <StackPanel Orientation="Horizontal" Margin="18,0,16,0" VerticalAlignment="Center" helpers:PanelSpacing.Spacing="12">
                                        <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="15">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Opacity" Value="0.75"/><Style.Triggers><DataTrigger Binding="{Binding IsTab2Active}" Value="True"><Setter Property="Opacity" Value="1"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Installation" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9090C0"/><Style.Triggers><DataTrigger Binding="{Binding IsTab2Active}" Value="True"><Setter Property="Foreground" Value="#FFFFFF"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Tab 3: Sauvegarde -->
                            <Border Cursor="Hand" Height="46">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding SelectTabCommand}" CommandParameter="3"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTab3Active}" Value="True"><Setter Property="Background" Value="#0F0F20"/></DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0C0C1C"/></Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Rectangle Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                                               RenderTransformOrigin="0.5,0.5">
                                        <Rectangle.RenderTransform><ScaleTransform/></Rectangle.RenderTransform>
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTab3Active}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                     From="0.1" To="1" Duration="0:0:0.28">
                                                                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6"/></DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                        <Rectangle.Fill><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#A855F7" Offset="0"/><GradientStop Color="#7C3AED" Offset="1"/></LinearGradientBrush></Rectangle.Fill>
                                    </Rectangle>
                                    <StackPanel Orientation="Horizontal" Margin="18,0,16,0" VerticalAlignment="Center" helpers:PanelSpacing.Spacing="12">
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="15">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Opacity" Value="0.75"/><Style.Triggers><DataTrigger Binding="{Binding IsTab3Active}" Value="True"><Setter Property="Opacity" Value="1"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Sauvegarde" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9090C0"/><Style.Triggers><DataTrigger Binding="{Binding IsTab3Active}" Value="True"><Setter Property="Foreground" Value="#FFFFFF"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Tab 4: Paramètres -->
                            <Border Cursor="Hand" Height="46">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding SelectTabCommand}" CommandParameter="4"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTab4Active}" Value="True"><Setter Property="Background" Value="#0F0F20"/></DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0C0C1C"/></Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Rectangle Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                                               RenderTransformOrigin="0.5,0.5">
                                        <Rectangle.RenderTransform><ScaleTransform/></Rectangle.RenderTransform>
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTab4Active}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                     From="0.1" To="1" Duration="0:0:0.28">
                                                                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6"/></DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                        <Rectangle.Fill><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#A855F7" Offset="0"/><GradientStop Color="#7C3AED" Offset="1"/></LinearGradientBrush></Rectangle.Fill>
                                    </Rectangle>
                                    <StackPanel Orientation="Horizontal" Margin="18,0,16,0" VerticalAlignment="Center" helpers:PanelSpacing.Spacing="12">
                                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="15">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Opacity" Value="0.75"/><Style.Triggers><DataTrigger Binding="{Binding IsTab4Active}" Value="True"><Setter Property="Opacity" Value="1"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Paramètres" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9090C0"/><Style.Triggers><DataTrigger Binding="{Binding IsTab4Active}" Value="True"><Setter Property="Foreground" Value="#FFFFFF"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </StackPanel>

                        <!-- Bottom: version + days used -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,12">
                            <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="6">
                                <TextBlock Text="v1.0" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock Text="·" FontSize="10" Foreground="#44445A"/>
                                <TextBlock FontSize="10" FontFamily="Segoe UI">
                                    <Run Text="{Binding DaysUsedDisplay}" Foreground="#7C3AED" FontWeight="Bold"/>
                                    <Run Text=" utilisé" Foreground="#8888AA"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- FiveM live indicator -->
                        <Border DockPanel.Dock="Bottom" Margin="14,0,14,10" CornerRadius="10" Padding="12,9">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1A0A0A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FiveMRunning}" Value="True">
                                            <Setter Property="Background" Value="#0A1A12"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,9,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#EF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FiveMRunning}" Value="True">
                                                    <Setter Property="Fill" Value="#10B981"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="FiveM fermé"/>
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FiveMRunning}" Value="True">
                                                    <Setter Property="Text" Value="FiveM actif"/>
                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DockPanel>
                </Border>

                <Rectangle Grid.Column="1" Fill="#12122A"/>

                <!-- ── Content Area ────────────────────────────────────── -->
                <Border Grid.Column="2" Background="{StaticResource ContentBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Bannière mise à jour -->
                        <Border Grid.Row="0"
                                Background="#071A10" BorderBrush="#14532D" BorderThickness="0,0,0,1"
                                Padding="22,10"
                                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolVis}}">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            helpers:PanelSpacing.Spacing="12">
                                    <TextBlock Text="&#xE930;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               Foreground="#10B981" VerticalAlignment="Center"/>
                                    <StackPanel VerticalAlignment="Center" helpers:PanelSpacing.Spacing="2">
                                        <TextBlock FontSize="12" FontWeight="Bold" Foreground="#10B981" FontFamily="Segoe UI">
                                            <Run Text="Mise à jour v"/><Run Text="{Binding UpdateVersion}"/><Run Text=" disponible !"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding UpdateChangelog}" FontSize="11"
                                                   Foreground="#6EE7B7" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                            VerticalAlignment="Center" helpers:PanelSpacing.Spacing="8">
                                    <Button Content="TÉLÉCHARGER" Style="{StaticResource PrimaryButton}"
                                            Padding="12,6" FontSize="11"
                                            Command="{Binding OpenUpdateUrlCommand}"/>
                                    <Button Style="{StaticResource ActionButton}" Padding="8,6" FontSize="11"
                                            ToolTip="Ignorer" Command="{Binding DismissUpdateCommand}">
                                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#9090B8"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ╔══ TAB 0: Tableau de bord ══════════════════╗ -->
                        <ScrollViewer Grid.Row="1" x:Name="Tab0Panel" Visibility="Visible"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <StackPanel Margin="32,28,32,20" helpers:PanelSpacing.Spacing="22">
                                <StackPanel helpers:PanelSpacing.Spacing="4">
                                    <TextBlock Text="Tableau de bord" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                    <TextBlock Text="Vue d'ensemble de votre installation FiveM."
                                               FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                </StackPanel>

                                <!-- Banner FiveM non installé -->
                                <Border CornerRadius="12" Padding="18,14" Background="#1A110A" BorderBrush="#4A2800" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FiveMDetected}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="14">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                   Foreground="#F59E0B" VerticalAlignment="Center"/>
                                        <StackPanel VerticalAlignment="Center" helpers:PanelSpacing.Spacing="2">
                                            <TextBlock Text="FiveM introuvable sur ce PC" FontSize="13" FontWeight="Bold"
                                                       Foreground="#F59E0B" FontFamily="Segoe UI"/>
                                            <TextBlock FontSize="11" Foreground="#C8873A" FontFamily="Segoe UI"
                                                       Text="Installez FiveM puis relancez EKIPPP pour accéder à toutes les fonctionnalités."/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Stats FiveM row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource StatCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel helpers:PanelSpacing.Spacing="4">
                                                <TextBlock Text="CACHE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding CacheSizeDisplay}" FontSize="28" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                                <TextBlock Text="FiveM.app\data" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Consolas"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="22" Opacity="0.85" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource StatCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel helpers:PanelSpacing.Spacing="4">
                                                <TextBlock Text="LOGS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding LogFileCount}" FontSize="28" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                                <TextBlock Text="FiveM.app\logs" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Consolas"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="22" Opacity="0.85" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="4" Style="{StaticResource StatCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel helpers:PanelSpacing.Spacing="4">
                                                <TextBlock Text="CRASHES" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding CrashFileCount}" FontSize="28" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                                <TextBlock Text="FiveM.app\crashes" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Consolas"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="&#xE945;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="22" Opacity="0.85" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="6" Style="{StaticResource StatCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel helpers:PanelSpacing.Spacing="4">
                                                <TextBlock Text="MODS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding ModsFileCount}" FontSize="28" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding ModsSizeDisplay}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="22" Opacity="0.85" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Stats PC row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- CPU -->
                                    <Border Grid.Column="0" Style="{StaticResource StatCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel helpers:PanelSpacing.Spacing="4">
                                                <TextBlock Text="CPU" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding CpuDisplay}" FontSize="28" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                                <ProgressBar Style="{StaticResource MiniProgressBar}"
                                                             Value="{Binding CpuPercent}" Maximum="100"/>
                                                <TextBlock Text="Utilisation processeur" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="22" Opacity="0.85" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                    <!-- RAM -->
                                    <Border Grid.Column="2" Style="{StaticResource StatCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel helpers:PanelSpacing.Spacing="4">
                                                <TextBlock Text="RAM" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding RamDisplay}" FontSize="18" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                                <ProgressBar Style="{StaticResource MiniProgressBar}"
                                                             Value="{Binding RamPercent}" Maximum="100"/>
                                                <TextBlock Text="Mémoire utilisée" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="22" Opacity="0.85" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                    <!-- DISQUE -->
                                    <Border Grid.Column="4" Style="{StaticResource StatCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel helpers:PanelSpacing.Spacing="4">
                                                <TextBlock Text="DISQUE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding DiskDisplay}" FontSize="18" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                                <TextBlock Text="Espace disponible" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="&#xE958;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="22" Opacity="0.85" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Cumulative stats row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource StatCard}">
                                        <StackPanel helpers:PanelSpacing.Spacing="4">
                                            <TextBlock Text="TOTAL LIBÉRÉ" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                            <TextBlock Text="{Binding TotalFreedDisplay}" FontSize="24" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                            <TextBlock Text="Tous nettoyages confondus" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource StatCard}">
                                        <StackPanel helpers:PanelSpacing.Spacing="4">
                                            <TextBlock Text="NETTOYAGES" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                            <TextBlock Text="{Binding TotalCleanCount}" FontSize="28" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                            <TextBlock Text="Nettoyages effectués" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="4" Style="{StaticResource StatCard}">
                                        <StackPanel helpers:PanelSpacing.Spacing="4">
                                            <TextBlock Text="VERSION FIVEM" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                            <TextBlock Text="{Binding FiveMVersion}" FontSize="16" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                            <TextBlock Text="Version installée" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Journal + Quick actions -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="240"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Journal -->
                                    <Border Grid.Column="0" Style="{StaticResource SectionCard}" Padding="22,18">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" helpers:PanelSpacing.Spacing="8">
                                                <Ellipse Width="6" Height="6" VerticalAlignment="Center" Fill="#7C3AED"/>
                                                <TextBlock Text="Journal d'activité" FontSize="12" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="160" CanContentScroll="False">
                                                <ItemsControl ItemsSource="{Binding Logs}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,3">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="14"/>
                                                                    <ColumnDefinition Width="58"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="10" VerticalAlignment="Center">
                                                                    <TextBlock.Foreground><Binding Path="Type" Converter="{StaticResource LogColor}"/></TextBlock.Foreground>
                                                                </TextBlock>
                                                                <TextBlock Grid.Column="1" Text="{Binding TimeDisplay}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"
                                                                           Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding Message}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"
                                                                           Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" FontFamily="Segoe UI"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                    <!-- Quick actions -->
                                    <Border Grid.Column="2" Style="{StaticResource SectionCard}" Padding="22,18">
                                        <StackPanel helpers:PanelSpacing.Spacing="10">
                                            <TextBlock Text="Actions rapides" FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                            <Button Style="{StaticResource PrimaryButton}"
                                                    Command="{Binding LaunchFiveMCommand}" Padding="14,10"
                                                    IsEnabled="{Binding FiveMRunning, Converter={StaticResource InvBool}}">
                                                <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="8">
                                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Lancer FiveM" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource PrimaryButton}"
                                                    Command="{Binding RefreshStatsCommand}" Padding="14,10">
                                                <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="8">
                                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Actualiser" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource PrimaryButton}"
                                                    Command="{Binding OpenFiveMFolderCommand}" Padding="14,10">
                                                <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="8">
                                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Ouvrir FiveM" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ╔══ TAB 1: Nettoyage ═════════════════════════╗ -->
                        <ScrollViewer Grid.Row="1" x:Name="Tab1Panel" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <StackPanel Margin="32,28,32,20" helpers:PanelSpacing.Spacing="16">
                                <StackPanel helpers:PanelSpacing.Spacing="4">
                                    <TextBlock Text="Nettoyage" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                    <TextBlock Text="Libérez de l'espace et optimisez votre installation FiveM."
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                </StackPanel>

                                <Border Style="{StaticResource SectionCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                        <StackPanel helpers:PanelSpacing.Spacing="8">
                                            <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="12">
                                                <TextBlock Text="Nettoyage complet" FontSize="18" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="data · logs · crashes" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"
                                                       Text="Supprime le cache data (sauf game-storage), tous les logs et tous les rapports de crash."/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI">
                                                <Run Text="{Binding CacheSizeDisplay, Mode=OneWay}"/> <Run Text="·"/> <Run Text="{Binding LogFileCount, Mode=OneWay}"/> <Run Text="log(s) ·"/> <Run Text="{Binding CrashFileCount, Mode=OneWay}"/> <Run Text="crash(es)"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="NETTOYER TOUT"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding CleanCacheCommand}"
                                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SectionCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                        <StackPanel helpers:PanelSpacing.Spacing="8">
                                            <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="12">
                                                <TextBlock Text="Supprimer les logs" FontSize="18" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="fichiers journaux" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"
                                                       Text="Supprime uniquement les fichiers de logs FiveM sans toucher au cache ni aux crashes."/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI">
                                                <Run Text="{Binding LogFileCount, Mode=OneWay}"/> <Run Text="fichier(s) dans FiveM.app\logs"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="SUPPRIMER"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding DeleteLogsCommand}"
                                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SectionCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                        <StackPanel helpers:PanelSpacing.Spacing="8">
                                            <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="12">
                                                <TextBlock Text="Supprimer les crashes" FontSize="18" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                                <TextBlock Text="rapports de crash" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"
                                                       Text="Supprime uniquement les rapports de crash sans toucher au cache ni aux logs."/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI">
                                                <Run Text="{Binding CrashFileCount, Mode=OneWay}"/> <Run Text="rapport(s) dans FiveM.app\crashes"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="SUPPRIMER"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding DeleteCrashesCommand}"
                                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ╔══ TAB 2: Installation ══════════════════════╗ -->
                        <ScrollViewer Grid.Row="1" x:Name="Tab2Panel" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <StackPanel Margin="32,28,32,20" helpers:PanelSpacing.Spacing="16">
                                <StackPanel helpers:PanelSpacing.Spacing="4">
                                    <TextBlock Text="Installation" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                    <TextBlock Text="Installez vos mods et packs directement dans FiveM. Glissez-déposez un fichier sur une carte."
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                </StackPanel>

                                <!-- Astuce glisser-déposer -->
                                <Border CornerRadius="10" Padding="14,10" Background="#0D0D1F"
                                        BorderBrush="#2A2A50" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="10">
                                        <TextBlock Text="&#x26A0;" FontSize="13" Foreground="#F59E0B" VerticalAlignment="Center"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" FontFamily="Segoe UI"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                                            <Run FontWeight="SemiBold" Foreground="#F59E0B">Glisser-déposer depuis certains dossiers peut ne pas fonctionner.</Run>
                                            <Run>Si ça bloque, déplacez d'abord le fichier sur le bureau, puis glissez-le depuis là.</Run>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Pack Citizen -->
                                <Border Style="{StaticResource SectionCard}" Tag="citizen"
                                        AllowDrop="True" DragOver="InstallCard_DragOver" Drop="InstallCard_Drop">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
