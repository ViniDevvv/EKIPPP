                                                           Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"
                                                           Text="Crée une archive ZIP complète de FiveM.app, sauvegardée dans vos Documents."/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="CRÉER"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Command="{Binding CreateBackupCommand}"
                                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Restaurer depuis fichier -->
                                    <Border Grid.Column="2" Style="{StaticResource SectionCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel helpers:PanelSpacing.Spacing="8">
                                                <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="10">
                                                    <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#A855F7" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Ouvrir le dossier" FontSize="16" FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                                </StackPanel>
                                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"
                                                           Text="Ouvre le dossier contenant toutes vos sauvegardes dans l'explorateur Windows."/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="OUVRIR"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Command="{Binding OpenBackupsFolderCommand}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Liste des sauvegardes -->
                                <Border Style="{StaticResource SectionCard}">
                                    <StackPanel helpers:PanelSpacing.Spacing="14">
                                        <!-- Header -->
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" helpers:PanelSpacing.Spacing="8">
                                                <Ellipse Width="6" Height="6" Fill="#7C3AED" VerticalAlignment="Center"/>
                                                <TextBlock Text="Sauvegardes existantes" FontSize="13" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Style="{StaticResource ActionButton}" Padding="10,6" FontSize="11"
                                                    Command="{Binding RefreshBackupsCommand}">
                                                <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="6">
                                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Rafraîchir" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <!-- Backups list -->
                                        <ItemsControl ItemsSource="{Binding Backups}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#0D0D1C" CornerRadius="10" Padding="16,12" Margin="0,0,0,6">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="&#xE896;" FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="20" Foreground="#7C3AED" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" helpers:PanelSpacing.Spacing="2">
                                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold"
                                                                           Foreground="White" FontFamily="Segoe UI"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="8">
                                                                    <TextBlock Text="{Binding DateDisplay}" FontSize="10"
                                                                               Foreground="#8888AA" FontFamily="Segoe UI"/>
                                                                    <TextBlock Text="·" FontSize="10" Foreground="#44445A"/>
                                                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="10"
                                                                               Foreground="#A855F7" FontFamily="Segoe UI" FontWeight="Bold"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                        VerticalAlignment="Center" helpers:PanelSpacing.Spacing="6">
                                                                <Button Content="Restaurer" Style="{StaticResource PrimaryButton}"
                                                                        Padding="10,6" FontSize="11"
                                                                        Command="{Binding DataContext.RestoreSelectedBackupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding FilePath}"/>
                                                                <Button Style="{StaticResource ActionButton}" Padding="8,6" FontSize="11"
                                                                        ToolTip="Supprimer cette sauvegarde"
                                                                        Command="{Binding DataContext.DeleteBackupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding FilePath}">
                                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#EF4444"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Empty state -->
                                        <TextBlock Text="Aucune sauvegarde trouvée. Créez-en une !"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                                                   HorizontalAlignment="Center" Margin="0,10">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Backups.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ╔══ TAB 4: Paramètres ════════════════════════════╗ -->
                        <ScrollViewer Grid.Row="1" x:Name="Tab4Panel" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <StackPanel Margin="32,28,32,20" helpers:PanelSpacing.Spacing="16">
                                <StackPanel helpers:PanelSpacing.Spacing="4">
                                    <TextBlock Text="Paramètres" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                    <TextBlock Text="Configurez le comportement d'EKIPPP."
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                </StackPanel>

                                <!-- À propos -->
                                <Border Style="{StaticResource SectionCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="52" Height="52" CornerRadius="14" Margin="0,0,18,0"
                                                ClipToBounds="True">
                                            <Image Source="pack://application:,,,/Assets/logo.png"
                                                   Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" helpers:PanelSpacing.Spacing="4">
                                            <StackPanel Orientation="Horizontal" helpers:PanelSpacing.Spacing="8">
                                                <TextBlock Text="EKIPPP" FontSize="18" FontWeight="Black"
                                                           Foreground="White" FontFamily="Segoe UI"/>
                                                <Border Background="#2A1A50" CornerRadius="6" Padding="8,2" VerticalAlignment="Center">
                                                    <TextBlock Text="v1.0" FontSize="10" FontWeight="Bold"
                                                               Foreground="#A855F7" FontFamily="Segoe UI"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Optimiseur FiveM · Fait avec passion"
                                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI">
                                                <Run Text="Utilisé depuis"/> <Run Text="{Binding DaysUsedDisplay}" Foreground="#A855F7" FontWeight="Bold"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" helpers:PanelSpacing.Spacing="6" HorizontalAlignment="Right">
                                            <TextBlock Text="Support &amp; Contact" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI" HorizontalAlignment="Right"/>
                                            <TextBlock FontSize="11" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Right">
                                                <Hyperlink NavigateUri="https://discord.gg/YUKQRUj9Qs"
                                                           RequestNavigate="DiscordLink_RequestNavigate"
                                                           Foreground="#A855F7" TextDecorations="None">
                                                    discord.gg/YUKQRUj9Qs
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SectionCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel helpers:PanelSpacing.Spacing="6">
                                            <TextBlock Text="Lancer au démarrage de Windows" FontSize="15" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                            <TextBlock Text="EKIPPP se lancera automatiquement avec Windows."
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Command="{Binding ToggleLaunchOnStartupCommand}"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Cursor="Hand" BorderThickness="0" Padding="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Width="44" Height="24" CornerRadius="12">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#2A2A45"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding LaunchOnStartup}" Value="True">
                                                                        <Setter Property="Background">
                                                                            <Setter.Value>
                                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                                                                    <GradientStop Color="#A855F7" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Ellipse Width="18" Height="18" Fill="White" VerticalAlignment="Center">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Margin" Value="3,0,0,0"/>
                                                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding LaunchOnStartup}" Value="True">
                                                                            <Setter Property="Margin" Value="0,0,3,0"/>
                                                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SectionCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel helpers:PanelSpacing.Spacing="6">
                                            <TextBlock Text="Nettoyage automatique au lancement" FontSize="15" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"
                                                       Text="Le cache FiveM sera nettoyé automatiquement à chaque démarrage d'EKIPPP (si FiveM est fermé)."/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Command="{Binding ToggleAutoCleanCommand}"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Cursor="Hand" BorderThickness="0" Padding="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Width="44" Height="24" CornerRadius="12">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#2A2A45"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AutoCleanOnLaunch}" Value="True">
                                                                        <Setter Property="Background">
                                                                            <Setter.Value>
                                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                                                                    <GradientStop Color="#A855F7" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Ellipse Width="18" Height="18" Fill="White" VerticalAlignment="Center">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Margin" Value="3,0,0,0"/>
                                                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AutoCleanOnLaunch}" Value="True">
                                                                            <Setter Property="Margin" Value="0,0,3,0"/>
                                                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>


                            </StackPanel>
                        </ScrollViewer>

                    </Grid>
                </Border>
            </Grid>

            <!-- ══ STATUS BAR ════════════════════════════════════════════ -->
            <Border Grid.Row="2" BorderBrush="#0E0E22" BorderThickness="0,1,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#08081A" Offset="0"/>
                        <GradientStop Color="#07070F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="22,0,22,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" helpers:PanelSpacing.Spacing="8">
                        <!-- Pulsing status dot -->
                        <Ellipse Width="6" Height="6" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#10B981"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Fill" Value="#F59E0B"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="PulseSB">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.25" Duration="0:0:0.65"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <RemoveStoryboard BeginStoryboardName="PulseSB"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    </StackPanel>
                    <ProgressBar Style="{StaticResource PurpleProgress}"
                                 Value="{Binding ProgressValue}" Maximum="100"
                                 Width="160" HorizontalAlignment="Right" VerticalAlignment="Center"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
