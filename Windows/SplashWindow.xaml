<Window x:Class="EKIPPP.Windows.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="500" Height="300"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True" ShowInTaskbar="False">
    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#07070F" Offset="0"/>
                <GradientStop Color="#0E0E22" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border BorderBrush="#7C3AED" BorderThickness="1" CornerRadius="20">
            <Grid>
                <!-- Glow -->
                <Ellipse Width="400" Height="300" Opacity="0.06" IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#7C3AED" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <!-- Logo image si disponible, sinon texte -->
                    <Image x:Name="LogoImage" MaxHeight="120" MaxWidth="380" Margin="0,0,0,20"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="FallbackText" Text="EKIPPP" FontSize="48" FontWeight="Black"
                               FontFamily="Segoe UI" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#A855F7" Offset="0"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="OPTIMISEUR FIVEM" FontSize="11" FontWeight="Bold"
                               Foreground="#8888BB" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" Margin="0,8,0,24"/>
                    <!-- Progress bar -->
                    <Border Height="3" CornerRadius="2" Background="#1A1A30" Width="300">
                        <Border x:Name="ProgressBar" Height="3" CornerRadius="2" HorizontalAlignment="Left" Width="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                    <GradientStop Color="#A855F7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>
                    <TextBlock x:Name="StatusText" Text="Chargement…" FontSize="10"
                               Foreground="#6060A0" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
