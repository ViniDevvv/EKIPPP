<Window x:Class="EKIPPP.Windows.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="600" Height="460"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Border CornerRadius="18" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#07070F" Offset="0"/>
                <GradientStop Color="#0E0E22" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border BorderBrush="#7C3AED" BorderThickness="1" CornerRadius="18">
            <Grid>
                <!-- Glow background -->
                <Ellipse Width="500" Height="400" Opacity="0.05" IsHitTestVisible="False"
                         HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-80,-60,0,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#7C3AED" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Grid Margin="40,36,40,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,28">
                        <Border Width="40" Height="40" CornerRadius="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                    <GradientStop Color="#3B0DA8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#7C3AED" Opacity="0.6"/>
                            </Border.Effect>
                            <TextBlock Text="E" FontSize="20" FontWeight="Black" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="20" FontWeight="Black" FontFamily="Segoe UI">
                                <Run Text="EKI" Foreground="#F0EFFF"/>
                                <Run Text="PPP" Foreground="#A855F7"/>
                            </TextBlock>
                            <TextBlock Text="OPTIMISEUR FIVEM" FontSize="9" FontWeight="Bold"
                                       Foreground="#8888BB" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Steps content -->
                    <Grid Grid.Row="1">

                        <!-- Étape 0: Licence -->
                        <StackPanel x:Name="Step0Panel" VerticalAlignment="Center">
                            <TextBlock Text="Contrat de licence" FontSize="22" FontWeight="Black"
                                       Foreground="White" FontFamily="Segoe UI" Margin="0,0,0,12"/>
                            <TextBlock Text="Veuillez lire et accepter les conditions avant de continuer."
                                       FontSize="11" Foreground="#8888BB" FontFamily="Segoe UI" Margin="0,0,0,12"/>
                            <Border Background="#0A0A18" BorderBrush="#1E1E38" BorderThickness="1"
                                    CornerRadius="10" Height="120">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,12">
                                    <StackPanel>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="19"
                                                   Foreground="#9090B8" FontFamily="Segoe UI">
                                            <Run Text="1. PRODUIT NUMÉRIQUE" FontWeight="Bold" Foreground="#C4C4E0"/>
                                            <LineBreak/>
                                            <Run Text="EKIPPP est un logiciel numérique livré instantanément. Aucun remboursement ne sera accordé une fois la clé de licence générée."/>
                                            <LineBreak/><LineBreak/>
                                            <Run Text="2. LICENCE PERSONNELLE" FontWeight="Bold" Foreground="#C4C4E0"/>
                                            <LineBreak/>
                                            <Run Text="La licence est liée à un seul PC. Toute revente ou partage de clé entraîne la révocation immédiate sans remboursement."/>
                                            <LineBreak/><LineBreak/>
                                            <Run Text="3. ABSENCE DE GARANTIE" FontWeight="Bold" Foreground="#C4C4E0"/>
                                            <LineBreak/>
                                            <Run Text="Le logiciel est fourni « en l'état ». L'éditeur ne garantit pas un gain de performances précis ni l'absence d'incompatibilité."/>
                                            <LineBreak/><LineBreak/>
                                            <Run Text="4. LIMITATION DE RESPONSABILITÉ" FontWeight="Bold" Foreground="#C4C4E0"/>
                                            <LineBreak/>
                                            <Run Text="Dans la limite autorisée par la loi, l'éditeur ne saurait être tenu responsable de tout dommage direct ou indirect résultant de l'utilisation du logiciel."/>
                                            <LineBreak/><LineBreak/>
                                            <Run Text="5. VIE PRIVÉE" FontWeight="Bold" Foreground="#C4C4E0"/>
                                            <LineBreak/>
                                            <Run Text="EKIPPP ne collecte aucune donnée personnelle. La vérification de licence transmet uniquement votre clé et un identifiant matériel au serveur d'activation."/>
                                        </TextBlock>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                            <CheckBox x:Name="AcceptCheckBox" Margin="0,14,0,0"
                                      Foreground="#C4C4E0" FontFamily="Segoe UI" FontSize="12"
                                      Checked="AcceptCheckBox_Changed" Unchecked="AcceptCheckBox_Changed">
                                Je comprends et j'accepte les termes du contrat de licence
                            </CheckBox>
                        </StackPanel>

                        <!-- Étape 1: Bienvenue -->
                        <StackPanel x:Name="Step1Panel" VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock Text="Bienvenue sur EKIPPP" FontSize="26" FontWeight="Black"
                                       Foreground="White" FontFamily="Segoe UI" Margin="0,0,0,16"/>
                            <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22"
                                       Foreground="#C4C4E0" FontFamily="Segoe UI"
                                       Text="EKIPPP est votre optimiseur FiveM tout-en-un. Nettoyez le cache, gérez vos mods, surveillez vos performances et gardez FiveM en pleine forme."/>
                            <StackPanel Margin="0,24,0,0" Orientation="Horizontal">
                                <TextBlock Text="✓" Foreground="#10B981" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Nettoyage automatique du cache" Foreground="#C4C4E0" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                <TextBlock Text="✓" Foreground="#10B981" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Installation de mods et packs" Foreground="#C4C4E0" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                <TextBlock Text="✓" Foreground="#10B981" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Surveillance CPU, RAM et disque en temps réel" Foreground="#C4C4E0" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Étape 2: Détection FiveM -->
                        <StackPanel x:Name="Step2Panel" VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock Text="Détection de FiveM" FontSize="26" FontWeight="Black"
                                       Foreground="White" FontFamily="Segoe UI" Margin="0,0,0,20"/>
                            <Border CornerRadius="12" Padding="20,16" Margin="0,0,0,0">
                                <Border.Background>
                                    <SolidColorBrush Color="#111120"/>
                                </Border.Background>
                                <Border BorderBrush="#1E1E38" BorderThickness="1" CornerRadius="12">
                                    <Grid>
                                        <StackPanel x:Name="FiveMFoundPanel" Orientation="Horizontal">
                                            <TextBlock Text="✓" Foreground="#10B981" FontSize="22" FontWeight="Bold"
                                                       VerticalAlignment="Center" Margin="0,0,14,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="FiveM détecté" FontSize="15" FontWeight="Bold"
                                                           Foreground="#10B981" FontFamily="Segoe UI"/>
                                                <TextBlock x:Name="FiveMPathText" FontSize="11" Foreground="#8888AA"
                                                           FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel x:Name="FiveMNotFoundPanel" Orientation="Horizontal" Visibility="Collapsed">
                                            <TextBlock Text="⚠" Foreground="#F59E0B" FontSize="22"
                                                       VerticalAlignment="Center" Margin="0,0,14,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="FiveM non détecté" FontSize="15" FontWeight="Bold"
                                                           Foreground="#F59E0B" FontFamily="Segoe UI"/>
                                                <TextBlock Text="Installez FiveM pour profiter de toutes les fonctionnalités."
                                                           FontSize="11" Foreground="#8888AA" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Border>
                        </StackPanel>

                        <!-- Étape 3: Prêt -->
                        <StackPanel x:Name="Step3Panel" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock Text="🎉" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock Text="Tout est prêt !" FontSize="26" FontWeight="Black"
                                       Foreground="White" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="EKIPPP est configuré et prêt à optimiser votre expérience FiveM."
                                       FontSize="13" Foreground="#C4C4E0" FontFamily="Segoe UI"
                                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,0"/>
                        </StackPanel>

                    </Grid>

                    <!-- Navigation buttons -->
                    <Grid Grid.Row="2" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Step indicators -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Ellipse x:Name="Dot0" Width="8" Height="8" Margin="4,0">
                                <Ellipse.Fill><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#A855F7" Offset="0"/><GradientStop Color="#7C3AED" Offset="1"/></LinearGradientBrush></Ellipse.Fill>
                            </Ellipse>
                            <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="#2A2A45" Margin="4,0"/>
                            <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="#2A2A45" Margin="4,0"/>
                            <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="#2A2A45" Margin="4,0"/>
                        </StackPanel>

                        <Button x:Name="PrevButton" Grid.Column="0" Content="Précédent"
                                Visibility="Collapsed" Click="PrevClick"
                                Padding="20,10" Cursor="Hand" Foreground="#C4C4E0"
                                BorderThickness="1" BorderBrush="#2A2A45" Background="#14142A"
                                FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="8" Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="NextButton" Grid.Column="2" Content="Suivant →"
                                Click="NextClick" Padding="20,10" Cursor="Hand"
                                Foreground="White" BorderThickness="0"
                                FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#7C3AED" Offset="0"/>
                                                <GradientStop Color="#6D28D9" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#7C3AED" Opacity="0.4"/>
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>

            </Grid>
        </Border>
    </Border>
</Window>
